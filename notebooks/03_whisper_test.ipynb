{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Whisper ASR Test\n",
    "\n",
    "Tasks: T12, T13, T14, T15, T16\n",
    "- Load Whisper model\n",
    "- Test on clean (near-field) audio\n",
    "- Compute baseline WER (single-channel, no separation)\n",
    "- Pipeline WER (after SepFormer)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys; sys.path.insert(0, \"../\")\n",
    "import torch, torchaudio\n",
    "import pandas as pd\n",
    "from src.asr.whisper_asr import WhisperASR\n",
    "from src.pipeline.data_loader import AISHELL5Loader\n",
    "from src.utils.audio import load_multichannel_audio\n",
    "from src.evaluation.metrics import compute_wer"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. Load Whisper and Basic Test"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "asr = WhisperASR(model_id=\"openai/whisper-small\", language=\"zh\")\n",
    "print(\"Whisper loaded.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test on a clean sample (channel 0, driver mic)\n",
    "loader = AISHELL5Loader(\"../data/dev\", max_samples=10)\n",
    "sample = loader[0]\n",
    "\n",
    "waveform, sr = load_multichannel_audio(sample.wav_path)\n",
    "ch0 = waveform[0]  # Driver channel\n",
    "\n",
    "result = asr.transcribe(ch0, sample_rate=sr)\n",
    "print(f\"Transcript: {result['text']}\")\n",
    "print(f\"Reference:  {list(sample.references.values())[0] if sample.references else 'N/A'}\")\n",
    "print(f\"Inference:  {result['inference_time_ms']:.0f}ms\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Baseline WER (50 samples, single channel)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# This runs evaluate.py for baseline mode\n",
    "# Alternatively run: python evaluate.py --split dev --mode baseline --n 50\n",
    "import subprocess\n",
    "r = subprocess.run(\n",
    "    [\"python\", \"../evaluate.py\", \"--split\", \"dev\", \"--mode\", \"baseline\", \"--n\", \"50\"],\n",
    "    capture_output=True, text=True\n",
    ")\n",
    "print(r.stdout[-2000:])\n",
    "if r.returncode != 0:\n",
    "    print(\"STDERR:\", r.stderr[-500:])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. Pipeline WER (Separation + ASR)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "r = subprocess.run(\n",
    "    [\"python\", \"../evaluate.py\", \"--split\", \"dev\", \"--mode\", \"pipeline\", \"--n\", \"50\"],\n",
    "    capture_output=True, text=True\n",
    ")\n",
    "print(r.stdout[-2000:])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Compare Baseline vs Pipeline"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "from pathlib import Path\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "baseline_path = Path(\"../outputs/metrics/summary_baseline_dev.json\")\n",
    "pipeline_path = Path(\"../outputs/metrics/summary_pipeline_dev.json\")\n",
    "\n",
    "if baseline_path.exists() and pipeline_path.exists():\n",
    "    with open(baseline_path) as f: baseline = json.load(f)\n",
    "    with open(pipeline_path) as f: pipeline = json.load(f)\n",
    "    \n",
    "    systems = [\"Baseline (single-ch)\", \"Pipeline (sep+ASR)\"]\n",
    "    wers = [\n",
    "        baseline[\"wer\"][\"mean\"]*100,\n",
    "        pipeline[\"wer\"][\"mean\"]*100,\n",
    "    ]\n",
    "    cpwers = [\n",
    "        baseline[\"cpwer\"][\"mean\"]*100,\n",
    "        pipeline[\"cpwer\"][\"mean\"]*100,\n",
    "    ]\n",
    "    \n",
    "    fig, axes = plt.subplots(1, 2, figsize=(10, 4))\n",
    "    axes[0].bar(systems, wers, color=[\"#d62728\", \"#1f77b4\"])\n",
    "    axes[0].set_title(\"WER Comparison\"); axes[0].set_ylabel(\"WER (%)\")\n",
    "    \n",
    "    axes[1].bar(systems, cpwers, color=[\"#d62728\", \"#1f77b4\"])\n",
    "    axes[1].set_title(\"cpWER Comparison\"); axes[1].set_ylabel(\"cpWER (%)\")\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"../outputs/figures/wer_comparison.png\", dpi=120)\n",
    "    plt.show()\n",
    "    \n",
    "    print(f\"Baseline WER: {wers[0]:.1f}%  |  Pipeline WER: {wers[1]:.1f}%\")\n",
    "    print(f\"Improvement: {wers[0]-wers[1]:.1f} percentage points\")\n",
    "else:\n",
    "    print(\"Run evaluate.py first to generate metric files.\")"
   ]
  }
 ],
