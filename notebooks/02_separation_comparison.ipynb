{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Speech Separation Comparison: SepFormer vs ConvTasNet\n",
    "\n",
    "Tasks: T07, T08, T09, T10, T11"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys; sys.path.insert(0, \"../\")\n",
    "import torch, torchaudio, time\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import soundfile as sf\n",
    "from pathlib import Path\n",
    "\n",
    "from src.separation.separator import SpeechSeparator, ChunkedSeparator\n",
    "from src.pipeline.data_loader import AISHELL5Loader\n",
    "from src.utils.audio import load_multichannel_audio, mix_channels\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. Load SepFormer"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "sep_sepformer = SpeechSeparator(model_name=\"sepformer-wsj02mix\", n_speakers=2)\n",
    "print(\"SepFormer initialized.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Run Separation on Single Sample"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "loader = AISHELL5Loader(\"../data/dev\", max_samples=5)\n",
    "sample = loader[0]\n",
    "\n",
    "waveform, sr = load_multichannel_audio(sample.wav_path)\n",
    "mono = mix_channels(waveform)  # [1, T]\n",
    "print(f\"Input: {sample.session_id}, shape={mono.shape}, dur={mono.shape[-1]/sr:.1f}s\")\n",
    "\n",
    "# Run separation\n",
    "result = sep_sepformer.separate(mono)\n",
    "sources = result[\"sources\"]\n",
    "print(f\"Output: {sources.shape[0]} sources, inference={result['inference_time_ms']:.0f}ms\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save separated tracks\n",
    "Path(\"../outputs/separation\").mkdir(exist_ok=True)\n",
    "for i, src in enumerate(sources):\n",
    "    out_path = f\"../outputs/separation/{sample.session_id}_spk{i+1}.wav\"\n",
    "    torchaudio.save(out_path, src.unsqueeze(0), sr)\n",
    "    print(f\"Saved: {out_path}\")\n",
    "\n",
    "# Visualize separated tracks\n",
    "fig, axes = plt.subplots(sources.shape[0]+1, 1, figsize=(12, 3*(sources.shape[0]+1)))\n",
    "t = np.linspace(0, mono.shape[-1]/sr, mono.shape[-1])\n",
    "axes[0].plot(t[::100], mono.squeeze().numpy()[::100], alpha=0.7, label=\"Mixture\")\n",
    "axes[0].set_title(\"Input Mixture (Mono)\"); axes[0].legend()\n",
    "\n",
    "for i, src in enumerate(sources):\n",
    "    t_src = np.linspace(0, src.shape[-1]/sr, src.shape[-1])\n",
    "    axes[i+1].plot(t_src[::100], src.numpy()[::100], alpha=0.7, label=f\"Source {i+1}\")\n",
    "    axes[i+1].set_title(f\"Separated Track {i+1}\")\n",
    "    axes[i+1].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"../outputs/figures/separation_example.png\", dpi=100)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. SepFormer vs ConvTasNet Comparison (20 samples)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Note: ConvTasNet requires asteroid package installed\n",
    "# Run: python evaluate_separation.py --n 20 --compare\n",
    "# Results will be saved in outputs/metrics/separation_metrics.csv\n",
    "\n",
    "import subprocess\n",
    "result = subprocess.run(\n",
    "    [\"python\", \"../evaluate_separation.py\", \"--n\", \"20\", \"--compare\", \"--data-dir\", \"../data/dev\"],\n",
    "    capture_output=True, text=True\n",
    ")\n",
    "print(result.stdout)\n",
    "if result.returncode != 0:\n",
    "    print(\"STDERR:\", result.stderr[:500])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Chunked Separation Test"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "chunked_sep = ChunkedSeparator(separator=sep_sepformer, chunk_sec=2.0, overlap_sec=0.2)\n",
    "\n",
    "waveform, sr = load_multichannel_audio(sample.wav_path)\n",
    "result = chunked_sep.process_file(waveform)\n",
    "\n",
    "print(f\"Chunks processed: {result['chunks_processed']}\")\n",
    "print(f\"Total inference: {result['total_inference_ms']:.0f}ms\")\n",
    "print(f\"Per chunk latencies: {[f'{v:.0f}ms' for v in result['per_chunk_latency_ms']]}\")\n",
    "print(f\"Output shape: {result['sources'].shape}\")"
   ]
  }
 ],
