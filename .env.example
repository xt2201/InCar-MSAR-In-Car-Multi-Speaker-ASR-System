# HuggingFace token – used by scripts/download_data.sh to pull
# pre-materialized AISHELL-5 splits from the HF dataset repo.
# Copy this file to .env and fill in your token.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override device for Whisper / ECAPA ("cpu" or "cuda")
# Defaults to auto-detect at runtime.
# INCAR_DEVICE=cpu
